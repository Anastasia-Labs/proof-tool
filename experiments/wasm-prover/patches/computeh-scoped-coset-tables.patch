+++ vendor/github.com/consensys/gnark/backend/groth16/bls12-381/prove_w6_test.go
@@ -0,0 +1,89 @@
+package groth16
+
+import (
+	"testing"
+
+	"github.com/consensys/gnark-crypto/ecc/bls12-381/fr"
+	"github.com/consensys/gnark-crypto/ecc/bls12-381/fr/fft"
+)
+
+func TestComputeHW6VectorEqualityAndCorruption(t *testing.T) {
+	a, b, c := fixedComputeHWitness(13)
+	domainLegacy := fft.NewDomain(16, fft.WithoutPrecompute())
+	legacy := computeHWithRuntime(cloneElements(a), cloneElements(b), cloneElements(c), domainLegacy, nil, false)
+
+	domainW6 := fft.NewDomain(16, fft.WithoutPrecompute())
+	yields := 0
+	optimized := computeHWithRuntime(cloneElements(a), cloneElements(b), cloneElements(c), domainW6, func() { yields++ }, true)
+	if yields != 7 {
+		t.Fatalf("W1 yield count with W6 = %d, want 7", yields)
+	}
+	assertElementVectorsEqual(t, optimized, legacy)
+
+	corruptA := cloneElements(a)
+	var one fr.Element
+	one.SetOne()
+	corruptA[0].Add(&corruptA[0], &one)
+	corrupt := computeHWithRuntime(corruptA, cloneElements(b), cloneElements(c), fft.NewDomain(16, fft.WithoutPrecompute()), nil, true)
+	if elementVectorsEqual(corrupt, legacy) {
+		t.Fatal("corrupt fixed-witness A vector unexpectedly produced the reference h vector")
+	}
+}
+
+func TestW6RebuildsInverseCosetTableInPlace(t *testing.T) {
+	domain := fft.NewDomain(16, fft.WithoutPrecompute())
+	table := buildHExpTable(nil, domain.FrMultiplicativeGen, 16)
+	firstAddress := &table[0]
+	forwardFirst := table[1]
+
+	table = buildHExpTable(table, domain.FrMultiplicativeGenInv, 16)
+	if &table[0] != firstAddress {
+		t.Fatal("W6 inverse coset table allocated a new backing array")
+	}
+	if table[1].Equal(&forwardFirst) {
+		t.Fatal("W6 inverse coset table did not overwrite forward powers")
+	}
+	want := make([]fr.Element, 16)
+	fft.BuildExpTable(domain.FrMultiplicativeGenInv, want)
+	assertElementVectorsEqual(t, table, want)
+}
+
+func fixedComputeHWitness(n int) ([]fr.Element, []fr.Element, []fr.Element) {
+	a := make([]fr.Element, n)
+	b := make([]fr.Element, n)
+	c := make([]fr.Element, n)
+	for i := 0; i < n; i++ {
+		a[i].SetUint64(uint64(3*i + 1))
+		b[i].SetUint64(uint64(5*i + 2))
+		c[i].SetUint64(uint64(7*i + 4))
+	}
+	return a, b, c
+}
+
+func cloneElements(src []fr.Element) []fr.Element {
+	return append([]fr.Element(nil), src...)
+}
+
+func assertElementVectorsEqual(t *testing.T, got, want []fr.Element) {
+	t.Helper()
+	if len(got) != len(want) {
+		t.Fatalf("h length = %d, want %d", len(got), len(want))
+	}
+	for i := range got {
+		if !got[i].Equal(&want[i]) {
+			t.Fatalf("h[%d] differs between W6 and baseline", i)
+		}
+	}
+}
+
+func elementVectorsEqual(a, b []fr.Element) bool {
+	if len(a) != len(b) {
+		return false
+	}
+	for i := range a {
+		if !a[i].Equal(&b[i]) {
+			return false
+		}
+	}
+	return true
+}

